# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encryption
SECRETS_ENCRYPTION_KEY=64-hex-chars-here

# Redis
REDIS_URL=redis://localhost:6379

# LiteLLM
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=your-litellm-key

# Postiz
POSTIZ_API_URL=http://localhost:3002
POSTIZ_API_KEY=your-postiz-key

# Webhook
WEBHOOK_SECRET=your-webhook-hmac-secret

# App
NODE_ENV=development
PORT=3001
SSE_PORT=3002
RENDER_PORT=3003

# Remotion
REMOTION_SERVE_URL=http://localhost:3004

# Internal
INTERNAL_SECRET=your-internal-service-secret
